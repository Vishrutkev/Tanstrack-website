---
// Figure plate: a product figure presented like a manifest plate —
// mono caption, hairline, no fake browser chrome. Renders, in order
// of preference: a slotted vignette, a real screenshot (src), or a
// dimension-true placeholder. Aspect is fixed so CLS stays zero.
interface Props {
  n: string;
  caption: string;
  slotId?: string;
  src?: string;
  width?: number;
  height?: number;
}
const { n, caption, slotId = '', src, width = 1600, height = 1000 } = Astro.props;
const hasViz = Astro.slots.has('default');
---

<figure class="plate reveal">
  {
    hasViz ? (
      <div class="plate-viz">
        <slot />
      </div>
    ) : src ? (
      <img src={src} alt={caption.toLowerCase()} width={width} height={height} loading="lazy" decoding="async" />
    ) : (
      <div class="plate-slot" role="img" aria-label={`Screenshot pending: ${caption.toLowerCase()}`}>
        <span>SCREENSHOT SLOT · {slotId}</span>
      </div>
    )
  }
  <figcaption><b>{n}</b> — {caption}</figcaption>
</figure>

<style>
  .plate {
    margin: 0;
    min-width: 0;
  }
  .plate img,
  .plate-slot,
  .plate-viz {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top left;
    border-radius: var(--r-2);
    border: 1px solid var(--line-dark);
    background: var(--panel);
    transition: border-color var(--t-reveal) var(--ease-arrive);
  }
  .plate:hover img,
  .plate:hover .plate-viz {
    border-color: rgba(125, 162, 255, 0.35);
  }
  .plate-viz {
    overflow: hidden;
  }
  .plate-viz :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .plate-slot {
    display: flex;
    align-items: center;
    justify-content: center;
    border-style: dashed;
    border-color: rgba(125, 162, 255, 0.35);
  }
  .plate-slot span {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--muted-dark);
  }
  figcaption {
    margin-top: 12px;
    font-family: var(--f-mono);
    font-size: 11px;
    font-stretch: 87.5%;
    letter-spacing: 0.08em;
    color: var(--muted-dark);
  }
  figcaption b {
    font-weight: 600;
    color: var(--signal-tint);
  }
</style>
