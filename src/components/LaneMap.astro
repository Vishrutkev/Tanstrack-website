---
// The signature: an abstracted Toronto↔US lane network drawn in the
// logo's geometry — orthogonal runs, rounded corners, one lit lane.
// LD-2481 (TOR→CHI) is the load whose journey structures the page.
// Ambient motion lives ONLY here; pulses hide under reduced motion
// and pause when the map is off-screen.
---

<svg
  id="lane-map"
  class="lane-map"
  viewBox="252 52 516 452"
  role="img"
  aria-label="Abstract map of freight lanes from Toronto to Montréal, Buffalo, Chicago, New Jersey, Atlanta, and Dallas. Load LD-2481, Toronto to Chicago, is highlighted."
>
  <!-- unlit lanes -->
  <path id="lane-mtl" class="lane" style="--i: 1" pathLength="1" d="M 596 140 V 104 A 20 20 0 0 1 616 84 H 700" />
  <path id="lane-buf" class="lane" style="--i: 2" pathLength="1" d="M 590 156 V 212 A 20 20 0 0 1 570 232 H 536" />
  <path id="lane-nj" class="lane" style="--i: 3" pathLength="1" d="M 604 156 V 280 A 20 20 0 0 0 624 300 H 668" />
  <path id="lane-atl" class="lane" style="--i: 4" pathLength="1" d="M 597 156 V 400 A 20 20 0 0 1 577 420 H 520" />
  <path id="lane-dal" class="lane" style="--i: 5" pathLength="1" d="M 588 156 H 320 A 20 20 0 0 0 300 176 V 432 A 20 20 0 0 1 280 452" />
  <!-- the lit lane: LD-2481 -->
  <path id="lane-chi" class="lane lit" style="--i: 6" pathLength="1" d="M 588 148 H 376 A 20 20 0 0 0 356 168 V 208" />

  <!-- nodes -->
  <g class="nodes">
    <rect class="node" x="695" y="79" width="10" height="10" rx="3" />
    <rect class="node" x="531" y="227" width="10" height="10" rx="3" />
    <rect class="node" x="663" y="295" width="10" height="10" rx="3" />
    <rect class="node" x="515" y="415" width="10" height="10" rx="3" />
    <rect class="node" x="275" y="447" width="10" height="10" rx="3" />
    <rect class="node lit-node" x="349" y="201" width="14" height="14" rx="4" />
    <rect class="hub" x="588" y="140" width="16" height="16" rx="5" />
  </g>

  <!-- labels -->
  <g class="labels" aria-hidden="true">
    <text x="614" y="136">TOR</text>
    <text x="712" y="88">MTL</text>
    <text x="524" y="256" text-anchor="middle">BUF</text>
    <text x="680" y="304">NJ</text>
    <text x="520" y="446" text-anchor="middle">ATL</text>
    <text x="280" y="478" text-anchor="middle">DAL</text>
    <text class="lit-label" x="338" y="212" text-anchor="end">CHI</text>
    <text class="lane-tag" x="482" y="138" text-anchor="middle">LD-2481</text>
  </g>

  <!-- pulses: loads moving now (ambient — signature only) -->
  <g class="pulses" aria-hidden="true">
    <circle class="pulse" r="3.5" fill="var(--headlight)" fill-opacity="0">
      <animateMotion begin="1.6s" dur="6s" repeatCount="indefinite"><mpath href="#lane-chi"></mpath></animateMotion>
      <animate attributeName="fill-opacity" values="0;1;1;0" keyTimes="0;0.06;0.9;1" begin="1.6s" dur="6s" repeatCount="indefinite"></animate>
    </circle>
    <circle class="pulse" r="3" fill="var(--signal-tint)" fill-opacity="0">
      <animateMotion begin="3.2s" dur="12s" repeatCount="indefinite"><mpath href="#lane-dal"></mpath></animateMotion>
      <animate attributeName="fill-opacity" values="0;0.55;0.55;0" keyTimes="0;0.05;0.92;1" begin="3.2s" dur="12s" repeatCount="indefinite"></animate>
    </circle>
  </g>
</svg>

<style>
  .lane-map {
    width: 100%;
    height: auto;
    display: block;
  }
  .lane {
    fill: none;
    stroke: var(--lane-faint);
    stroke-width: 2;
    stroke-linecap: round;
  }
  .lane.lit {
    stroke: var(--signal);
    stroke-width: 3;
  }
  .node {
    fill: var(--panel);
    stroke: var(--signal-tint);
    stroke-opacity: 0.55;
    stroke-width: 1.5;
  }
  .lit-node {
    stroke-opacity: 0.9;
  }
  .hub {
    fill: var(--signal);
  }
  .labels text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    fill: var(--muted-dark);
  }
  .labels text:first-child {
    fill: var(--headlight);
    font-weight: 600;
  }
  .lit-label {
    fill: var(--headlight);
  }
  .lane-tag {
    fill: var(--signal-tint);
    font-size: 10px;
  }

  /* draw-in: only when motion is allowed; otherwise fully drawn */
  @media (prefers-reduced-motion: no-preference) {
    .lane {
      stroke-dasharray: 1;
      animation: draw var(--t-draw) var(--ease-arrive) both;
      animation-delay: calc(300ms + var(--i) * 70ms);
    }
    .nodes,
    .labels {
      opacity: 0;
      animation: appear 500ms var(--ease-arrive) 1100ms forwards;
    }
    @keyframes draw {
      from {
        stroke-dashoffset: 1;
      }
      to {
        stroke-dashoffset: 0;
      }
    }
    @keyframes appear {
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pulse {
      display: none;
    }
  }
</style>

<script>
  const svg = document.getElementById('lane-map') as unknown as SVGSVGElement | null;
  if (svg && typeof svg.pauseAnimations === 'function') {
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
      svg.pauseAnimations();
    } else if ('IntersectionObserver' in window) {
      new IntersectionObserver(([e]) => {
        if (e.isIntersecting) svg.unpauseAnimations();
        else svg.pauseAnimations();
      }).observe(svg);
    }
  }
</script>
