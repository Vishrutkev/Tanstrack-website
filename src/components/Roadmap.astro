---
import Chip from './Chip.astro';
import { ROADMAP } from '../copy';
---

<section id={ROADMAP.id} class="stop container" aria-labelledby="roadmap-h">
  <div class="grid">
    <div>
      <div class="stop-head reveal">
        <span class="stop-node" aria-hidden="true"></span>
        <Chip parts={['NEXT LANES', 'IN DEVELOPMENT']} />
      </div>
      <h2 id="roadmap-h" class="reveal">{ROADMAP.h2}</h2>
      <p class="lede reveal">{ROADMAP.body}</p>
    </div>
    <svg
      class="future reveal"
      viewBox="0 0 340 190"
      aria-label="Dashed, not-yet-built lanes labelled fleet, drivers, and trucks"
      role="img"
    >
      <rect x="18" y="88" width="14" height="14" rx="4" class="hub"></rect>
      <path d="M 32 95 H 120 A 16 16 0 0 0 136 79 V 40 A 16 16 0 0 1 152 24 H 236" class="dash"></path>
      <path d="M 32 95 H 252" class="dash"></path>
      <path d="M 32 95 H 120 A 16 16 0 0 1 136 111 V 150 A 16 16 0 0 0 152 166 H 236" class="dash"></path>
      <text x="246" y="28">{ROADMAP.lanes[0]}</text>
      <text x="262" y="99">{ROADMAP.lanes[1]}</text>
      <text x="246" y="170">{ROADMAP.lanes[2]}</text>
    </svg>
  </div>
</section>

<style>
  .stop {
    padding-block: 0 clamp(64px, 9vh, 96px);
  }
  .grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(220px, 2fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    border-top: 1px solid var(--line-ink);
    padding-top: clamp(56px, 8vh, 88px);
  }
  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .future {
      max-width: 360px;
    }
  }
  .lede {
    max-width: 58ch;
  }
  .future {
    width: 100%;
    height: auto;
  }
  .hub {
    fill: var(--signal-deep);
  }
  .dash {
    fill: none;
    stroke: var(--muted-ink);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 3 7;
    opacity: 0.55;
  }
  .future text {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    fill: var(--muted-ink);
  }
  /* unbuilt lanes assemble when the map arrives */
  @media (prefers-reduced-motion: no-preference) {
    .future.in .dash {
      animation: lane-settle 1.3s var(--ease-arrive) both;
    }
    .future.in .dash:nth-of-type(2) {
      animation-delay: 130ms;
    }
    .future.in .dash:nth-of-type(3) {
      animation-delay: 260ms;
    }
    .future.in text,
    .future.in .hub {
      animation: lane-appear 500ms var(--ease-arrive) 650ms both;
    }
    @keyframes lane-settle {
      from {
        stroke-dashoffset: 50;
        opacity: 0.08;
      }
    }
    @keyframes lane-appear {
      from {
        opacity: 0;
      }
    }
  }
</style>
